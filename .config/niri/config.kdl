// This config is in KDL format: https://kdl.dev
// "/-" comments out the following node.
// See the wiki for a full description of the configuration:
// https://yalter.github.io/niri/Configuration:-Introduction

// Input device configuration.
// See the full list of options in the wiki:
// https://yalter.github.io/niri/Configuration:-Input
input {
    keyboard {
        xkb {
            layout "us"
            variant "intl"
        }
        numlock
    }

    // The following sections include libinput settings.
    // Omitting settings disables them or leaves them at default values.
    // All commented settings here are examples, not defaults.
    touchpad {
        // off
        tap
        // dwt
        // dwtp
        // drag false
        // drag-lock
        natural-scroll
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "two-finger"
        // disabled-on-external-mouse
    }

    mouse {
        // off
        // natural-scroll
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "no-scroll"
    }

    trackpoint {
        // off
        // natural-scroll
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "on-button-down"
        // scroll-button 273
        // scroll-button-lock
        // middle-emulation
    }

    // Uncomment this to make the mouse move to the center of newly focused windows.
    // warp-mouse-to-focus

    // Automatically focus windows and outputs when moving the mouse over them.
    // Setting max-scroll-amount="0%" makes it work only on fully visible windows.
    focus-follows-mouse max-scroll-amount="50%"

    mod-key "Alt"
}

cursor {
    xcursor-theme "Qogir-white-cursors"
    xcursor-size 21
    hide-when-typing
    hide-after-inactive-ms 3000
}

// You can configure outputs by name, which can be found
// by running `niri msg outputs` inside a niri instance.
// The built-in laptop monitor is usually called "eDP-1".
// More info in the wiki:
// https://yalter.github.io/niri/Configuration:-Outputs
// Remember to uncomment the node by removing "/-"!
output "VGA-1" {
    mode "1366x768@59.790"
    scale 1
    // position x=1280 y=0
}

// Settings that affect how windows are placed and sized.
// More info in the wiki:
// https://yalter.github.io/niri/Configuration:-Layout
layout {
    // Defines spacing around windows in logical pixels.
    gaps 16

    // When centering a column on focus change, options are:
    // - "never", default behavior, focusing an off-screen column keeps it at screen edge
    // - "always", always center the focused column
    // - "on-overflow", center only if it doesn't fit with the previously focused column
    center-focused-column "never"

    // Customize widths used by "switch-preset-column-width" (Mod+R).
    preset-column-widths {
        // Proportion defines width as a fraction of output width including gaps.
        // Example: proportion 0.25 fits four windows exactly.
        // Default presets are 1/3, 1/2, and 2/3.
        proportion 0.33333
        proportion 0.5
        proportion 0.66667

        // Fixed defines exact width in logical pixels.
        // fixed 1920
    }

    // You can also customize heights for "switch-preset-window-height" (Mod+Shift+R).
    // preset-window-heights { }

    // Default width for new windows.
    // default-column-width { proportion 5.0; }
    default-column-width {}

    // Focus ring and border rendering explanation...
    // (kept identical meaning, shortened here for clarity)

    focus-ring {
        on
        width 2

        // Colors can be defined in multiple ways:
        // CSS names, hex, rgb(), rgba(), hsl(), etc.

        active-color "#fabd2f"
        inactive-color "#fe8019"

        // Gradients are supported (CSS linear-gradient style)
    }

    border {
        off
        width 4
        active-color "#ffc87f"
        inactive-color "#505050"
        urgent-color "#9b0000"
    }

    shadow {
        // on
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
    }

    struts {
        // left 64
        // right 64
        // top 64
        // bottom 64
    }
}

// Startup processes
spawn-at-startup "xwayland-satellite"
spawn-at-startup "awww-daemon"
spawn-at-startup "waybar"

environment {
    DISPLAY ":0"
}

// Use spawn-sh-at-startup for shell commands
spawn-sh-at-startup "awww img $HOME/.config/fuzzel/Wallpaper/current.png"
spawn-sh-at-startup "~/.config/niri/swayidle"

hotkey-overlay {
    // skip-at-startup
}

// Ask clients to disable client-side decorations if possible
prefer-no-csd

// Screenshot path (~ expands to home)
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// Animations
animations {
    // off
    // slowdown 3.0
}

// Window rules

// Workaround for WezTerm initial config bug
window-rule {
    match app-id=r#"^org\.wezfurlong\.wezterm$"#
    default-column-width {}
}

// Firefox PiP floating
window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

window-rule {
    match app-id="alacritty-float"
    open-floating true
}

window-rule {
    match app-id="Thunar|thunar"
    open-floating true
    default-column-width { proportion 0.55; }
    default-window-height { fixed 600; }
}

window-rule {
    match is-floating=true
    opacity 0.9
}

// Rounded corners example
window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
}

// Keybindings
binds {
    // Keys are modifiers + XKB key name

    Mod+Shift+Slash { show-hotkey-overlay; }

    // App launches
    Alt+T { spawn "alacritty"; }
    Alt+A { spawn "abaddon"; }
    Alt+Z { spawn "zeditor"; }
    Alt+G { spawn "gimp"; }
    Alt+E { spawn "thunar"; }
    Alt+F { spawn "firefox"; }

    Alt+Shift+T { spawn "alacritty" "--class" "alacritty-float"; }
    Ctrl+Shift+Escape { spawn "alacritty" "--class" "btop" "-e" "btop"; }

    Alt+D { spawn "fuzzel"; }

    Super+Alt+L { spawn "~/.config/swaylock/config"; }

    // Volume keys (PipeWire)
    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.05+ -l 1.0"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.05-"; }
    XF86AudioMute        allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }

    // Media keys
    XF86AudioPlay allow-when-locked=true { spawn-sh "playerctl play-pause"; }

    // Brightness
    XF86MonBrightnessUp allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "+10%"; }

    // Window management
    Alt+Q repeat=false { close-window; }

    Alt+Left  { focus-column-left; }
    Alt+Right { focus-column-right; }

    Alt+Shift+Left { move-column-left; }

    Alt+1 { focus-workspace 1; }
    Alt+Shift+1 { move-column-to-workspace 1; }

    Alt+BracketLeft  { consume-or-expel-window-left; }
    Alt+BracketRight { consume-or-expel-window-right; }

    Mod+R { switch-preset-column-width; }

    Alt+V { toggle-window-floating; }

    Alt+W { toggle-column-tabbed-display; }

    Print { screenshot; }

    Alt+Shift+E { quit; }

    Alt+Shift+P { power-off-monitors; }

    // Test notification
    Alt+M { spawn "bash" "-c" "pkill mako; mako & sleep 0.3 && notify-send 'Mako Test' 'Notification working!'"; }

    // Toggle waybar
    Mod5+slash { spawn "bash" "-c" "if pgrep -x waybar > /dev/null; then pkill -x waybar; else waybar & fi"; }
}
